# Environment Variables Example
# Copy this as .env and fill in your actual values

# ===========================================
# TELEGRAM BOT CONFIGURATION
# ===========================================
# Get your bot token from @BotFather on Telegram
# 1. Open Telegram
# 2. Search for @BotFather
# 3. Send /newbot
# 4. Follow the instructions
# 5. Copy the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ===========================================
# MONGODB CONFIGURATION
# ===========================================
# LOCAL MONGODB (Default - Recommended for development)
# Make sure MongoDB is running locally!
MONGODB_URI=mongodb://localhost:27017/BotData

# OR USE MONGODB ATLAS (Cloud - For production)
# 1. Create account at https://www.mongodb.com/cloud/atlas
# 2. Create a cluster
# 3. Create a database user
# 4. Copy the connection string
# 5. Replace username:password with your credentials
# Uncomment the line below and comment out the local one above
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/BotData?retryWrites=true&w=majority

# ===========================================
# CLOUDINARY CONFIGURATION
# ===========================================
# Get these from your Cloudinary Dashboard
# 1. Create account at https://cloudinary.com/
# 2. Go to your Dashboard
# 3. Copy the credentials below
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
# Node environment (development or production)
NODE_ENV=development

# Bot name for logging
BOT_NAME=EELU_IT_Material

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
# Comma-separated Telegram user IDs of admins
# Get your ID from @userinfobot on Telegram
# 1. Open Telegram
# 2. Search for @userinfobot
# 3. Send any message
# 4. Copy your user ID
# Multiple admins: ADMIN_IDS=123456789,987654321,555555555
ADMIN_IDS=your_telegram_user_id_here